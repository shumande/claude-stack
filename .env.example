# Anthropic — required for Claude Code
ANTHROPIC_API_KEY=

# Supabase MCP — optional, if you use Supabase
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# Vercel MCP — optional, if you use Vercel
VERCEL_TOKEN=

# Higgsfield MCP — optional, for image/video
HIGGSFIELD_API_KEY=

# atypica MCP — optional, for synthetic-persona research
ATYPICA_USER_TOKEN=

# Context7 MCP — optional, for live library docs
CONTEXT7_API_KEY=

# Notion MCP — optional
NOTION_TOKEN=

# Slack MCP — optional
SLACK_BOT_TOKEN=

# Google MCPs (Gmail / Calendar / Drive) use OAuth — filled in on first run.
# No env vars required here.

# DSGVO.pro MCP — public endpoint, no key required.
